# Pi API URL (로컬 개발용) — 센서/최근 읽기 등
VITE_API_BASE=http://192.168.60.254:8765
# 로컬 dev 전용: 제어 POST 대상 (없으면 VITE_API_BASE). 프로덕션 빌드에서는 무시되고 /api/control 프록시 사용.
# VITE_CONTROL_API_BASE=http://192.168.60.254:1880

# ——— Vercel(서버) 환경변수 ———
# 기상청: /api/kma 프록시 (클라이언트 VITE_KMA_SERVICE_KEY 대신 서버에서 호출)
KMA_SERVICE_KEY=여기에_기상청_인코딩_서비스키
# 제어: 브라우저 → POST /api/control → 여기 URL 로 프록시 (끝 슬래시 없이)
CONTROL_API_UPSTREAM=https://your-node-red-or-tunnel.example.com

# 기상청 API (로컬에서 직접 호출할 때만 필요, Vercel 배포 시 서버리스 프록시 사용)
VITE_KMA_SERVICE_KEY=여기에_기상청_서비스키
VITE_KMA_NX=60
VITE_KMA_NY=127

# ESP32-CAM MJPEG 스트리밍 URL (ACTUATOR 탭 라이브 스트림)
VITE_ESP32CAM_URL=http://ESP32CAM_IP/stream

# Overview — 최신 사진 URL (둘 중 하나)
# A) 서비스 계정+Drive API: /api/drive-latest-photo  (GOOGLE_* 환경변수 필요)
# B) Google Apps Script(키 불필요): /api/apps-script-photo  (Vercel에 APPS_SCRIPT_WEBAPP_URL 만)
# VITE_DRIVE_LATEST_PHOTO_URL=https://프로젝트명.vercel.app/api/apps-script-photo
# (구 A) # VITE_DRIVE_LATEST_PHOTO_URL=https://프로젝트명.vercel.app/api/drive-latest-photo
# Vercel(서버)만: Apps Script B안 사용 시 — APPS_SCRIPT_WEBAPP_URL=https://script.google.com/macros/s/xxxx/exec
# 끄기: VITE_DRIVE_LATEST_PHOTO_URL=off
# 자동 재요청 주기(밀리초), 기본 600000 = 10분
# VITE_DRIVE_PHOTO_REFRESH_MS=600000
